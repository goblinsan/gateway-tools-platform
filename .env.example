# Internal upstream service URLs (reachable from the gateway host/container)
STT_SERVICE_URL=http://192.168.0.63:5101
CV_SERVICE_URL=http://192.168.0.63:5201

# Persistent app data root mounted into the container. The gateway managed-app
# preset maps DATA_ROOT_HOST on the host to /data in the container.
DATA_ROOT=/data
DATA_ROOT_HOST=./data

# Optional slot-specific env file used by the gateway deploy wrapper.
APP_ENV_FILE=.env.local
HOST_PORT=3000

# S3-compatible object storage for large STT uploads.
# Cloudflare R2 example:
#   OBJECT_STORE_BUCKET=tools-audio
#   OBJECT_STORE_REGION=auto
#   OBJECT_STORE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   OBJECT_STORE_ACCESS_KEY_ID=<r2-access-key>
#   OBJECT_STORE_SECRET_ACCESS_KEY=<r2-secret>
#   OBJECT_STORE_FORCE_PATH_STYLE=false
OBJECT_STORE_BUCKET=
OBJECT_STORE_REGION=auto
OBJECT_STORE_ENDPOINT=
OBJECT_STORE_ACCESS_KEY_ID=
OBJECT_STORE_SECRET_ACCESS_KEY=
OBJECT_STORE_FORCE_PATH_STYLE=false
