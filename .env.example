# Environment variables for gateway-tools-platform
#
# Copy this file to .env.local and fill in values for your environment.
# Never commit .env.local to source control.

# ── Development shim ──────────────────────────────────────────────────────────
# In production, Cloudflare Access injects Cf-Access-Authenticated-User-Email
# automatically.  For local development you can point a local reverse proxy at
# the app and inject the header there, or set this variable and add a small
# dev-only shim that reads it.  Leave blank in production.
#
# CF_ACCESS_DEV_EMAIL=you@example.com

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute path to the durable data root where per-user workspaces are stored.
# The operator should mount a persistent host volume at this path so that
# artifacts and session metadata survive container restarts and blue/green swaps.
# Defaults to /data when not set.
#
# DATA_ROOT=/data

# ── Internal services ─────────────────────────────────────────────────────────
# Base URLs for the internal STT and CV services.  These are never exposed to
# the browser – the Next.js API routes act as an authenticated proxy.
# Both variables are required in production; the app will throw at request time
# if they are missing.
#
# STT_SERVICE_URL=http://stt-service:8080
# CV_SERVICE_URL=http://cv-service:8080

# ── Runtime ───────────────────────────────────────────────────────────────────
# PORT and HOSTNAME are set in the Dockerfile; override here only if needed.
# PORT=3000
# HOSTNAME=0.0.0.0
